{
  "name": "japanese-learning-app-backend",
  "version": "1.0.0",
  "description": "Backend API for Japanese learning app",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "sync:corpus": "ts-node src/scripts/syncOpenCorpus.ts",
    "process:tatoeba": "ts-node src/scripts/processTatoebaDump.ts",
    "grade:tatoeba": "ts-node src/scripts/gradeTatoebaCorpus.ts",
    "build": "tsc",
    "test": "jest"
  },
  "keywords": [
    "japanese",
    "learning",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "mongoose": "^7.0.0",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.1",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
